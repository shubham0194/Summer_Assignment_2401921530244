class Solution {
    public int maxProfit(int[] prices) {
        int buy = prices[0];
        int mpft= 0;

        for(int i=1;i<prices.length;i++)
        {
            if(prices[i]<buy)
            buy=prices[i];
            else
            mpft=Math.max(mpft,prices[i]-buy);
        }
        return mpft;
    }
}